{
  "name": "@pdffill/core",
  "version": "0.6.0",
  "description": "Discover, diagnose, and fill PDF AcroForms with pdf-lib (no pdftk)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./test-fixtures": {
      "types": "./dist/test-helpers/create-fixture.d.ts",
      "import": "./dist/test-helpers/create-fixture.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/test-helpers/create-fixture.ts --format esm --dts --clean",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@pdf-lib/fontkit": "^1.1.1",
    "ajv": "^8.17.1",
    "pdf-lib": "^1.17.1"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "pdf",
    "acroform",
    "pdf-lib",
    "form",
    "fill",
    "pdf-form"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pdffill/pdffill.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/pdffill/pdffill/issues"
  },
  "homepage": "https://github.com/pdffill/pdffill/tree/main/packages/core#readme",
  "publishConfig": {
    "access": "public"
  }
}
